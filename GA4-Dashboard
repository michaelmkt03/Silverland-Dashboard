  destroy("nvr-chart");charts["nvr-chart"]=new Chart(document.getElementById("nvr-chart"),{type:"bar",data:{labels:nk,datasets:[
    {label:"Sessions",data:nk.map(k=>nvr[k][0]),backgroundColor:COLORS[0]+"DD",borderRadius:5,yAxisID:"y"},
    {label:"Key events",data:nk.map(k=>nvr[k][1]),backgroundColor:COLORS[3]+"DD",borderRadius:5,yAxisID:"y1"}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:"top",labels:{usePointStyle:true,boxWidth:8}}},scales:{y:{beginAtZero:true,position:"left"},y1:{beginAtZero:true,position:"right",grid:{display:false}}}}});
  barChart("age-chart",AGE.map(r=>r[0]),AGE.map(r=>r[1]),{color:COLORS[2]+"DD",fmt:v=>fmtN(v)});
  mountTable("interest-tbl",[{t:"Sở thích (affinity)"},{t:"Active users",num:true,fmt:fmtN}],INTERESTS.map(r=>[r[0],r[1]]));
  const D=state.cmp;
  const ctyRows=Object.keys(cty).map(k=>{const a=cty[k],b=ctyP[k]||[0,0,0,0,0,0];return [CTRY_VI[k]||k,a[0],a[1],a[0]?a[3]/a[0]:0,a[2],a[4],a[5],BOT_CTRY[k]?1:0,b[0],b[5]];}).filter(r=>r[1]>0).sort((x,y)=>y[1]-x[1]);
  const ccols=[{t:"Quốc gia",fmt:(v,r)=>r[7]?`${v} <span class="tag bot">nghi bot</span>`:v},{t:"Sessions",num:true,fmt:fmtN}];
  if(D)ccols.push({t:"Δ Sess",num:true,fmt:(v,r)=>deltaTxt(r[1],r[8])});
  ccols.push({t:"Users",num:true,fmt:fmtN},{t:"Engagement",num:true,fmt:fmtPct},{t:"Key events",num:true,fmt:fmtN},{t:"Giao dịch",num:true,fmt:fmtN},{t:"Doanh thu",num:true,rev:true,fmt:fmtVND});
  if(D)ccols.push({t:"Δ DT",num:true,fmt:(v,r)=>deltaTxt(r[6],r[9])});
  mountTable("country-tbl",ccols,ctyRows);
  const cityRows=Object.keys(city).map(k=>{const a=city[k],b=cityP[k]||[0,0,0,0,0];return [k,a[0],a[1],a[2],a[3],a[4],b[0],b[4]];}).filter(r=>r[1]>0).sort((x,y)=>y[1]-x[1]);
  const cicols=[{t:"Thành phố"},{t:"Sessions",num:true,fmt:fmtN}];
  if(D)cicols.push({t:"Δ Sess",num:true,fmt:(v,r)=>deltaTxt(r[1],r[6])});
  cicols.push({t:"Users",num:true,fmt:fmtN},{t:"Key events",num:true,fmt:fmtN},{t:"Giao dịch",num:true,fmt:fmtN},{t:"Doanh thu",num:true,rev:true,fmt:fmtVND});
  if(D)cicols.push({t:"Δ DT",num:true,fmt:(v,r)=>deltaTxt(r[5],r[7])});
  mountTable("city-tbl",cicols,cityRows);
}
function render(){
  if(curView==="overview")renderOverview();else if(curView==="acq")renderAcq();else if(curView==="paid")renderPaid();
  else if(curView==="ai")renderAI();else if(curView==="organic")renderOrganic();else if(curView==="conv")renderConv();else if(curView==="journey")renderJourney();
  let dl;if(FILTER_VIEWS.includes(curView))dl=state.label+" ("+state.start+" → "+state.end+")";else if(curView==="ai")dl="90 ngày qua (cố định)";else dl="28 ngày qua (cố định)";
  document.getElementById("foot").innerHTML="Nguồn: GA4 &middot; property www.silverlandhotels.com (340245620) &middot; tiền tệ VND &middot; múi giờ Asia/Saigon &middot; dữ liệu đến "+DATA_DATE+" &middot; Đang xem: "+dl+". Snapshot tĩnh, không tự refresh. Doanh thu hiển thị theo triệu/tỷ VND.";
}
const TITLES={overview:["Tổng quan","Hiệu suất marketing toàn site"],acq:["Acquisition (kênh)","So sánh kênh theo GA4 Channel Group"],paid:["Paid Search","Kênh Paid Search (GA4 Channel Group)"],ai:["AI Assistant","Traffic từ trợ lý AI (ChatGPT, Perplexity...)"],organic:["Organic & SEO","Traffic tự nhiên từ Search"],conv:["Conversion & Funnel","Tỷ lệ chuyển đổi, doanh thu và phễu"],journey:["Chân dung & hành trình","Nhân khẩu học và hành vi khách"]};
document.getElementById("nav").addEventListener("click",e=>{const a=e.target.closest("a");if(!a)return;
  document.querySelectorAll("#nav a").forEach(x=>x.classList.remove("active"));a.classList.add("active");curView=a.dataset.view;closePanel();
  document.querySelectorAll(".view").forEach(v=>v.classList.remove("active"));document.getElementById("v-"+curView).classList.add("active");
  document.getElementById("view-title").textContent=TITLES[curView][0];document.getElementById("view-sub").textContent=TITLES[curView][1];
  const isF=FILTER_VIEWS.includes(curView);document.getElementById("datebtn").style.opacity=isF?"1":".55";document.getElementById("datebtn").style.cursor=isF?"pointer":"default";
  document.getElementById("datelabel").textContent=isF?state.label:FIXED_LABEL[curView];document.getElementById("cmppill").style.display=(isF&&state.cmp)?"inline-block":"none";render();});
/* THEME */
function setTheme(t){
  if(t==="dark")document.documentElement.setAttribute("data-theme","dark");
  else document.documentElement.removeAttribute("data-theme");
  document.getElementById("themeicon").innerHTML=t==="dark"?"&#9728;":"&#127769;";
  document.getElementById("themelabel").textContent=t==="dark"?"Sáng":"Tối";
  try{localStorage.setItem("svl-theme",t);}catch(e){}
  applyChartTheme();render();
}
document.getElementById("themebtn").onclick=()=>{
  const cur=document.documentElement.getAttribute("data-theme")==="dark"?"dark":"light";
  setTheme(cur==="dark"?"light":"dark");
};
(function initTheme(){let t="light";try{t=localStorage.getItem("svl-theme")||(window.matchMedia&&window.matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light");}catch(e){}
  if(t==="dark"){document.documentElement.setAttribute("data-theme","dark");document.getElementById("themeicon").innerHTML="&#9728;";document.getElementById("themelabel").textContent="Sáng";}
  applyChartTheme();})();
document.getElementById("datelabel").textContent=state.label;document.getElementById("cmppill").style.display=state.cmp?"inline-block":"none";render();
</script>
