    else chg=`<div class="chg flat">n/a <span class="prevsmall">vs kỳ trước</span></div>`;}
  const sp=spark?sparkSVG(spark,scolor||"#1f6feb"):"";
  return `<div class="kpi ${hl?'hl':''}"><div class="lab">${lab}</div><div class="val">${val}</div>${chg}${sp}</div>`;}
